<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="1-create-roles" author="mila">
        <createTable tableName="roles">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2-insert-default-roles" author="mila">
        <insert tableName="roles">
            <column name="name" value="ROLE_USER"/>
        </insert>
        <insert tableName="roles">
            <column name="name" value="ROLE_ADMIN"/>
        </insert>
    </changeSet>

    <changeSet id="3-create-users" author="mila">
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="login" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="first_name" type="VARCHAR(100)"/>
            <column name="second_name" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <createIndex tableName="users" indexName="idx_users_login" unique="true">
            <column name="login"/>
        </createIndex>
        <createIndex tableName="users" indexName="idx_users_email" unique="true">
            <column name="email"/>
        </createIndex>
    </changeSet>

    <changeSet id="4-create-users-roles" author="mila">
        <createTable tableName="users_roles">
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="role_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="users_roles" columnNames="user_id, role_id" constraintName="pk_users_roles"/>
        <addForeignKeyConstraint baseTableName="users_roles" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_users_roles_user" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="users_roles" baseColumnNames="role_id"
                                 referencedTableName="roles" referencedColumnNames="id"
                                 constraintName="fk_users_roles_role" onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="5-create-user-profile" author="mila">
        <createTable tableName="user_profile">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="birth_day" type="DATE"/>
            <column name="status" type="VARCHAR(50)"/>
            <column name="rating_points" type="INT"/>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="user_profile" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_user_profile_user" onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="6-create-initiatives" author="mila">
        <createTable tableName="initiatives">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="author_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="VARCHAR(100)"/>
            <column name="description" type="VARCHAR(2000)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="initiatives" baseColumnNames="author_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_initiatives_author" onDelete="CASCADE"/>
        <createIndex tableName="initiatives" indexName="idx_initiatives_author_id">
            <column name="author_id"/>
        </createIndex>
        <createIndex tableName="initiatives" indexName="idx_initiatives_category">
            <column name="category"/>
        </createIndex>
    </changeSet>

    <changeSet id="7-create-applications" author="mila">
        <createTable tableName="applications">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="applicant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="initiative_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="message" type="VARCHAR(1000)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="applications" baseColumnNames="applicant_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_applications_applicant" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="applications" baseColumnNames="initiative_id"
                                 referencedTableName="initiatives" referencedColumnNames="id"
                                 constraintName="fk_applications_initiative" onDelete="CASCADE"/>
        <createIndex tableName="applications" indexName="idx_applications_applicant_id">
            <column name="applicant_id"/>
        </createIndex>
        <createIndex tableName="applications" indexName="idx_applications_initiative_id">
            <column name="initiative_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="8-add-initiative-status" author="mila">
        <addColumn tableName="initiatives">
            <column name="status" type="VARCHAR(50)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="moderation_reason" type="VARCHAR(500)"/>
        </addColumn>
    </changeSet>

    <changeSet id="9-add-contact-info-to-initiatives" author="mila">
        <addColumn tableName="initiatives">
            <column name="contact_info" type="VARCHAR(500)"/>
        </addColumn>
    </changeSet>

    <changeSet id="10-create-notifications" author="mila">
        <createTable tableName="notifications">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="message" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="is_read" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="link" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="notifications" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_notifications_user" onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="11-add-city-to-initiatives" author="mila">
        <addColumn tableName="initiatives">
            <column name="city" type="VARCHAR(100)" defaultValue="Москва">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>